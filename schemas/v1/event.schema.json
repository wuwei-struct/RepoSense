{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "type": "object",
  "required": ["type", "key", "confidence"],
  "properties": {
    "event_id": { "type": "integer" },
    "type": { "type": "string" },
    "key": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "meta_json": { "type": "string" }
  }
}

