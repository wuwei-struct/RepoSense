{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding",
  "type": "object",
  "required": ["concept", "rule_id", "confidence", "primary_eid"],
  "properties": {
    "fid": { "type": "integer" },
    "concept": { "type": "string" },
    "rule_id": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "primary_eid": { "type": "integer", "minimum": 1 },
    "meta_json": { "type": "string" }
  }
}

