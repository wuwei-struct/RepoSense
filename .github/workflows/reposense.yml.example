name: RepoSense CI
on:
  push:
    branches: ["main"]
  pull_request:
    branches: ["main"]
jobs:
  scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - name: Install
        run: pip install -e .
      - name: Run scan
        run: python -m reposense scan . --out analysis_runs --ruleset rulesets/basic --budget presets/default.json
      - name: Export SARIF
        run: python -m reposense export sarif analysis_runs/repo-*/ --out reposense.sarif.json
      - name: Upload SARIF
        uses: github/codeql-action/upload-sarif@v3
        with:
          sarif_file: reposense.sarif.json
